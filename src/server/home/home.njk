{% extends "layouts/page.njk" %}

{% from "govuk/components/button/macro.njk" import govukButton %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <h1 class="govuk-heading-xl">AI Assistant</h1>

      <p class="govuk-body">
        This AI Assistant is an internal test service hosted on AWS-managed infrastructure. AI-generated responses may be inaccurate, incomplete, or biased and must be reviewed before use.
      </p>

      <p class="govuk-body">
        User prompts and system responses are processed within Defra's AWS environment and are not used to train AI models <strong>by default</strong>, or shared with other customers or model providers. Data is handled in line with Defra security and information management policies.
      </p>

      <p class="govuk-body">
        Do not enter personal data, sensitive information, or content classified above <strong>OFFICIAL</strong>. You remain responsible for how AI-generated content is used, including checking outputs for accuracy and appropriateness.
      </p>

      <p class="govuk-body">
        By using this service, you agree to use it responsibly and in accordance with the Defra Group GenAI Usage Guidelines and ICT Acceptable Use Policy.
      </p>

      {{ govukButton({
        text: "Start Chat",
        href: "/start"
      }) }}

      {{ govukButton({
        text: "Upload File",
        href: "/upload",
        classes: "govuk-button--secondary"
      }) }}

      {{ govukButton({
        text: "Knowledge Management",
        href: "/knowledge",
        classes: "govuk-button--secondary"
      }) }}

    </div>
  </div>
{% endblock %}
