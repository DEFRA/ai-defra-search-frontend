{% extends "layouts/page.njk" %}

{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% set breadcrumbs = [
        { text: 'Home', href: '/' },
        { text: 'Knowledge Management', href: '/knowledge' },
        { text: group.title, href: '/knowledge/' + group.groupId },
        { text: 'Documents', href: '/knowledge/' + group.groupId + '/documents' }
      ] %}

      {% if errorMessage %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [{ text: errorMessage }]
        }) }}
      {% endif %}

      <p class="govuk-body govuk-!-margin-bottom-6">
        <a href="/knowledge/{{ group.groupId }}" class="govuk-back-link">Back to {{ group.title }}</a>
      </p>

      <h1 class="govuk-heading-xl">Documents</h1>

      <p class="govuk-body">
        View documents in {{ group.title }}. <a href="/upload" class="govuk-link">Upload new documents</a>
      </p>

      {% if documents.length === 0 %}
        <p class="govuk-body">No documents in this knowledge group.</p>
      {% else %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th class="govuk-table__header" style="width: 35%">File name</th>
              <th class="govuk-table__header">Status</th>
              <th class="govuk-table__header">Chunks</th>
              <th class="govuk-table__header">Upload ID</th>
              <th class="govuk-table__header">Created</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for doc in documents %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ doc.file_name }}</td>
                <td class="govuk-table__cell">
                  {% if doc.status === 'ready' %}
                    <strong class="govuk-tag govuk-tag--green">{{ doc.status }}</strong>
                  {% elif doc.status === 'in_progress' %}
                    <strong class="govuk-tag govuk-tag--blue">{{ doc.status }}</strong>
                  {% elif doc.status === 'failed' %}
                    <strong class="govuk-tag govuk-tag--red">{{ doc.status }}</strong>
                  {% else %}
                    <strong class="govuk-tag govuk-tag--grey">{{ doc.status }}</strong>
                  {% endif %}
                </td>
                <td class="govuk-table__cell">{{ doc.chunk_count | default('—') }}</td>
                <td class="govuk-table__cell"><code class="govuk-!-font-size-14">{{ doc.cdp_upload_id }}</code></td>
                <td class="govuk-table__cell">{{ doc.created_at_display or '—' }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    </div>
  </div>
{% endblock %}
