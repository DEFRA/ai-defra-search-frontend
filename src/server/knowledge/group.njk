{% extends "layouts/page.njk" %}

{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "govuk/components/inset-text/macro.njk" import govukInsetText %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
      {% set breadcrumbs = [
        { text: 'Home', href: '/' },
        { text: 'Knowledge Management', href: '/knowledge' },
        { text: group.title, href: '/knowledge/' + group.groupId }
      ] %}

      {% if errorMessage %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [{ text: errorMessage }]
        }) }}
      {% endif %}

      {% if request.query.error %}
        {{ govukErrorSummary({
          titleText: "Error",
          errorList: [{ text: request.query.error }]
        }) }}
      {% endif %}

      <p class="govuk-body govuk-!-margin-bottom-6">
        <a href="/knowledge" class="govuk-back-link">Back to groups</a>
      </p>

      <h1 class="govuk-heading-xl">{{ group.title }} <span class="govuk-!-font-weight-regular">({{ group.groupId }})</span></h1>

      {% if group.description %}
        <p class="govuk-body-l govuk-!-margin-top-2">{{ group.description }}</p>
      {% endif %}

      {% if group.owner %}
        <p class="govuk-body"><strong>Owner:</strong> {{ group.owner }}</p>
      {% endif %}

      <hr class="govuk-section-break govuk-section-break--visible govuk-section-break--l">

      <h2 class="govuk-heading-m">Documents</h2>
      <p class="govuk-body">Upload documents to this group via <a href="/upload" class="govuk-link">Upload</a>.</p>
      {% if documents.length === 0 %}
        <p class="govuk-body">No documents in this group yet.</p>
      {% else %}
        <table class="govuk-table">
          <thead class="govuk-table__head">
            <tr class="govuk-table__row">
              <th class="govuk-table__header">File name</th>
              <th class="govuk-table__header">Status</th>
              <th class="govuk-table__header">Chunks</th>
            </tr>
          </thead>
          <tbody class="govuk-table__body">
            {% for doc in documents %}
              <tr class="govuk-table__row">
                <td class="govuk-table__cell">{{ doc.file_name }}</td>
                <td class="govuk-table__cell">
                  {% if doc.status == 'ready' %}
                  <span class="govuk-tag govuk-tag--green">{{ doc.status }}</span>
                  {% elif doc.status == 'in_progress' %}
                  <span class="govuk-tag govuk-tag--blue">{{ doc.status }}</span>
                  {% elif doc.status == 'failed' %}
                  <span class="govuk-tag govuk-tag--red">{{ doc.status }}</span>
                  {% else %}
                  <span class="govuk-tag govuk-tag--grey">{{ doc.status }}</span>
                  {% endif %}
                </td>
                <td class="govuk-table__cell">{{ doc.chunk_count or '—' }}</td>
              </tr>
            {% endfor %}
          </tbody>
        </table>
      {% endif %}
    </div>
  </div>
{% endblock %}
