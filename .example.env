AWS_REGION=eu-west-2
AWS_DEFAULT_REGION=eu-west-2
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

AUTH_ENABLED=true
API_BASE_URL=http://localhost:8086
KNOWLEDGE_API_URL=http://localhost:8085
CDP_UPLOADER_URL=http://localhost:7337
CDP_UPLOAD_CALLBACK_URL=http://ai-defra-search-frontend:3000/upload/callback
UPLOAD_BUCKET_NAME=my-bucket
MS_ENTRA_TENANT_ID=
MS_ENTRA_CLIENT_ID=
MS_ENTRA_CLIENT_SECRET=
MS_ENTRA_REDIRECT_HOST=http://localhost:3000

# HTTP Timeout configurations (in milliseconds)
CHAT_API_TIMEOUT_MS=10000
KNOWLEDGE_API_TIMEOUT_MS=10000
CDP_UPLOADER_TIMEOUT_MS=30000

# Redis timeout configurations (in milliseconds)
REDIS_CONNECT_TIMEOUT=5000
REDIS_COMMAND_TIMEOUT=5000
REDIS_KEEPALIVE=30000
REDIS_ENABLE_READY_CHECK=true
REDIS_MAX_RETRIES_PER_REQUEST=3

AI_DEFRA_SEARCH_AGENT_API_KEY=test-api-key

